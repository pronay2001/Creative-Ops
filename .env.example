# ── Database ──────────────────────────────────────────
# PostgreSQL connection string (auto-set by Replit if using built-in DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SESSION_SECRET=replace-with-random-string
APP_URL=https://your-replit-url.repl.co

# ── Keka HR API ───────────────────────────────────────
# Get these from Keka Admin > Settings > API
KEKA_COMPANY=hoichoi
KEKA_CLIENT_ID=
KEKA_CLIENT_SECRET=
KEKA_API_KEY=

# ── Microsoft Graph API (Email) ───────────────────────
# Azure Portal > Entra ID > App Registrations > Your App
# Required permission: Mail.Send (Application) with admin consent
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MAIL_FROM=creativeops@hoichoi.tv
