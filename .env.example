# ── Database ──────────────────────────────────────────
# PostgreSQL connection string (auto-set by Replit if using built-in DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SESSION_SECRET=replace-with-random-string
APP_URL=https://your-replit-url.repl.co
# Absolute base URL used for deep links inside email + Teams notifications.
# Falls back to APP_URL → REPLIT_DOMAINS → REPLIT_DEV_DOMAIN → http://localhost:PORT.
APP_BASE_URL=https://your-replit-url.repl.co

# ── Microsoft Graph API (Email + Teams) ───────────────
# Azure Portal > Entra ID > App Registrations > Your App
# Required Application permissions (with admin consent):
#   - Mail.Send                  (email notifications)
#   - Chat.Create                (create 1:1 chats with the bot user)
#   - ChatMessage.Send           (send chat messages on behalf of the bot user)
#   - User.Read.All              (look up recipient + bot user IDs by email)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Mailbox / user used as the email sender AND as the Teams bot identity.
MAIL_FROM=creativeops@hoichoi.tv
# Optional: pin the Teams bot to a specific Azure AD user object id
# (uuid). When unset, the bot is resolved from MAIL_FROM at runtime.
TEAMS_BOT_USER_ID=
